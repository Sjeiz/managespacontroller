	"sensors": {
		"spa_temp_1": {
			"name"         : "Spa Temperature 1",
			"device_class" : "temperature",
			"config_topic" : "homeassistant/sensor/spa-controller/spa_temp_1/config",
			"state_topic"  : "spa-controller/spa_temp_1",
			"sensor_type"  : "w1sensor",
			"filename"     : "/sys/bus/w1/devices/28-1da3d4431598/w1_slave",
